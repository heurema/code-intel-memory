# Maintainer: Heurema <https://github.com/heurema>
pkgname=code-intel-memory
pkgver=0.8.1
pkgrel=1
pkgdesc="Fast code intelligence engine for AI coding agents — single static binary MCP server"
arch=('x86_64' 'aarch64')
url="https://github.com/heurema/code-intel-memory"
license=('MIT')
provides=("$pkgname")
conflicts=("$pkgname")

source_x86_64=("${pkgname}-${pkgver}-linux-amd64.tar.gz::https://github.com/heurema/code-intel-memory/releases/download/v${pkgver}/code-intel-memory-linux-amd64.tar.gz")
source_aarch64=("${pkgname}-${pkgver}-linux-arm64.tar.gz::https://github.com/heurema/code-intel-memory/releases/download/v${pkgver}/code-intel-memory-linux-arm64.tar.gz")

sha256sums_x86_64=('dbd3b92ea870ef240b63059f26bda15015f76ef9978931bebc3a0f9d09470973')
sha256sums_aarch64=('d2f842d1365da5c35d9c5796f57a821c9745267350994346735e1e6e04d46091')

package() {
    install -Dm755 "${srcdir}/code-intel-memory" \
        "${pkgdir}/usr/bin/code-intel-memory"
    install -Dm644 "${srcdir}/LICENSE" \
        "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
    # Third-party attribution bundle (present in archives since v0.8.1)
    if [ -f "${srcdir}/THIRD_PARTY_NOTICES.md" ]; then
        install -Dm644 "${srcdir}/THIRD_PARTY_NOTICES.md" \
            "${pkgdir}/usr/share/licenses/${pkgname}/THIRD_PARTY_NOTICES.md"
    fi
}
